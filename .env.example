# ─── Environment Variables ───────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your values.
# NEVER commit .env files to version control.
# All variables prefixed with VITE_ are exposed to the client bundle.

# ─── Application ─────────────────────────────────────────────────────────────
VITE_APP_NAME=TaskFlow
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION="Enterprise task management platform"

# ─── API (Future Use) ────────────────────────────────────────────────────────
# When backend is connected, set the API base URL.
# VITE_API_URL=https://api.example.com/v1
# VITE_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_API_TIMEOUT_MS=10000

# ─── Authentication (Future Use) ─────────────────────────────────────────────
# VITE_AUTH_DOMAIN=https://auth.example.com
# VITE_AUTH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_AUTH_AUDIENCE=https://api.example.com

# ─── Monitoring & Analytics ──────────────────────────────────────────────────
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxx
# VITE_SENTRY_ENVIRONMENT=development
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Feature Flags ───────────────────────────────────────────────────────────
VITE_ENABLE_TIMER=true
VITE_ENABLE_AVATAR_CONSTRUCTOR=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# ─── Security ────────────────────────────────────────────────────────────────
# Content Security Policy (when using CSP meta tag)
# VITE_CSP_DEFAULT_SRC="'self'"
# VITE_CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
# VITE_CSP_STYLE_SRC="'self' 'unsafe-inline'"
# VITE_CSP_IMG_SRC="'self' data: https:"

# ─── Performance ─────────────────────────────────────────────────────────────
VITE_LAZY_LOAD_IMAGES=true
VITE_ENABLE_IMAGE_OPTIMIZATION=true
VITE_CONSOLE_LOG_LEVEL=warn  # Options: debug, log, warn, error, silent

# ─── Internationalization (Future Use) ───────────────────────────────────────
# VITE_DEFAULT_LOCALE=en-US
# VITE_SUPPORTED_LOCALES=en-US,ru-RU,de-DE,fr-FR,es-ES,zh-CN,ja-JP
# VITE_FALLBACK_LOCALE=en-US
